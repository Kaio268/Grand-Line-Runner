	end,

	[3516522609] = function(receiptInfo, player, profile, DataManager: Types.DataManager)
		DataManager:AddValue(player, "HiddenLeaderstats.Speed", 10)
		DataManager:AddValue(player, "TotalStats.TotalSpeed", 10)
