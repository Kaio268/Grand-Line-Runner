        <Item class="ModuleScript" referent="60">
          <Properties>
            <string name="Name">CometMerchant</string>
            <string name="Source">local CometMerchant = {
	
	All_Things = {
		["Potions.x2MoneyTime"] = {
			Display_name = "x2 Money Boost",
			
			Chance = 40,
			Amount = math.random(120,300),
			
			Stock = math.random(1,3),
			
