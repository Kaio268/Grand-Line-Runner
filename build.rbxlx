          <Item class="ModuleScript" referent="100">
            <Properties>
              <string name="Name">BrainrotVariants</string>
              <string name="Source"><![CDATA[local BrainrotVariants = {}

BrainrotVariants.Order = { "Normal", "Golden", "Diamond" }

BrainrotVariants.Versions = {
	Normal = {
		Chance = 90,
		Folder = nil,
		Prefix = "",
