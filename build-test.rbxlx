        <Item class="ModuleScript" referent="65">
          <Properties>
            <string name="Name">GrandLineRushCrewCatalog</string>
            <string name="Source"><![CDATA[local CrewCatalog = {
	Starter = {
		Name = "Deckhand Rookie",
		Rarity = "Common",
	},

	ByRarity = {
		Common = {
			"Deckhand Rookie",
			"Galley Hand",
			"Cabin Runner",
			"Mast Climber",
		},
		Uncommon = {
			"Navigator Scout",
			"Sailmaker",
