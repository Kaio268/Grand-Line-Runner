				AnchorPoint = Vector2.new(0.5, 0.5),
				BackgroundColor3 = surface.fill,
				BackgroundTransparency = 0.12,
				BorderSizePixel = 0,
				Position = UDim2.fromScale(0.5, 0.5),
				Size = UDim2.new(1, -12, 1, -12),
				ZIndex = props.zIndex and (props.zIndex + 2) or nil,
			}, {
				Corner = e("UICorner", {
