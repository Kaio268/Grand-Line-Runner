                <string name="Name">Array</string>
                <string name="Source"><![CDATA[local ES7Types = require(script.Parent.Parent:WaitForChild('es7-types'))

export type Array<T> = ES7Types.Array<T>

return {
	concat = require(script:WaitForChild('concat')),
