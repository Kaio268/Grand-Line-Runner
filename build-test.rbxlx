                    <string name="Name">SingleEventManager</string>
                    <string name="Source"><![CDATA[-- ROBLOX upstream: https://github.com/Roblox/roact/blob/b2ba9cf4c219c2654e6572219a68d0bf1b541418/src/SingleEventManager.lua
--[[
