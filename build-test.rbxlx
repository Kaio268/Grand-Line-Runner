	ResetData : (self: any, userId: number) -> boolean,
	SetValue : (self: any, player: Player, path: string, newValue: (string | number | boolean | {any?})?) -> (),
	SubValue : (self: any, player: Player, path: string, subValue: (number | {any?})) -> (),
