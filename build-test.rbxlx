                  <string name="Name">SchedulerHostConfig.mock</string>
                  <string name="Source"><![CDATA[-- ROBLOX upstream: https://github.com/facebook/react/blob/5474a83e258b497584bed9df95de1d554bc53f89/packages/scheduler/src/forks/SchedulerHostConfig.mock.js
--[[*
